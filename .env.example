PROJECT_NAME=Task Tracker
VERSION=0.1.0

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=task_tracker

REDIS_HOST=localhost
REDIS_PORT=6379

# Derived by the app from POSTGRES_* / REDIS_* (not read as env vars):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/task_tracker
# REDIS_URL=redis://localhost:6379

# Generate a secure random value for production (e.g. openssl rand -hex 32)
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
