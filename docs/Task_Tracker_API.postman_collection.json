{
  "info": {
    "name": "Task Tracker API",
    "description": "Postman collection for Task Tracker API. Set `baseUrl` and run Auth → Login first to populate `accessToken`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "projectId", "value": "1" },
    { "key": "taskId", "value": "1" },
    { "key": "commentId", "value": "1" },
    { "key": "notificationId", "value": "1" },
    { "key": "userId", "value": "2" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"secret123\",\n  \"name\": \"Demo User\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.access_token);",
                  "  pm.collectionVariables.set('refreshToken', body.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "demo@example.com" },
                { "key": "password", "value": "secret123" }
              ]
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create project",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('projectId', String(pm.response.json().id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Project\",\n  \"description\": \"Created from Postman\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/projects"
          }
        },
        {
          "name": "List projects",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/projects"
          }
        },
        {
          "name": "Get project",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}"
          }
        },
        {
          "name": "Add member",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}/members/{{userId}}"
          }
        },
        {
          "name": "Project activity",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects/{{projectId}}/activity?skip=0&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "projects", "{{projectId}}", "activity"],
              "query": [
                { "key": "skip", "value": "0" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('taskId', String(pm.response.json().id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"First task\",\n  \"description\": \"Do the thing\",\n  \"priority\": \"high\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/projects/{{projectId}}/tasks"
          }
        },
        {
          "name": "List tasks",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects/{{projectId}}/tasks?sort_by=created_at&skip=0&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "projects", "{{projectId}}", "tasks"],
              "query": [
                { "key": "sort_by", "value": "created_at" },
                { "key": "skip", "value": "0" },
                { "key": "limit", "value": "50" },
                { "key": "status", "value": "", "disabled": true },
                { "key": "priority", "value": "", "disabled": true },
                { "key": "assignee_id", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Search tasks",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects/{{projectId}}/tasks/search?q=First&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "projects", "{{projectId}}", "tasks", "search"],
              "query": [
                { "key": "q", "value": "First" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Update task status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}/status"
          }
        },
        {
          "name": "Get task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}"
          }
        },
        {
          "name": "Patch task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"First task (updated)\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}"
          }
        },
        {
          "name": "Delete task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}"
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Create comment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('commentId', String(pm.response.json().id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"Looks good\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}/comments"
          }
        },
        {
          "name": "List comments",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}/comments"
          }
        },
        {
          "name": "Update comment",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"Updated comment\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/comments/{{commentId}}"
          }
        },
        {
          "name": "Delete comment",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/comments/{{commentId}}"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Unread notifications",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/notifications/unread"
          }
        },
        {
          "name": "Mark notification read",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
            },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/notifications/{{notificationId}}/read"
          }
        }
      ]
    }
  ]
}
